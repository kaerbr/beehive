{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Europe/Berlin",
  "assignees": [
    "kaerbr"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "kubernetes/apps/**/!(kustomization).yaml"
    ]
  },
  "flux": {
    "managerFilePatterns": [
      "/(?:^|/)gotk-components\\.ya?ml$/",
      "kubernetes/**/helm.yaml"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Talos version in version file, README badge and Dockerfile",
      "managerFilePatterns": [
        "talos/nodes/**/*.yaml",
        "README.md",
        ".devcontainer/Dockerfile"
      ],
      "matchStrings": [
        "(?s)machine:\\s+install:\\s+.*?image: .+:(?<currentValue>v[\\d.]+)",
        "badge/Talos-(?<currentValue>v[\\d.]+)-",
        "ARG TALOS_VERSION=(?<currentValue>v[\\d.]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "siderolabs/talos"
    },
    {
      "customType": "regex",
      "description": "Update Kubernetes version in version file and README badge",
      "managerFilePatterns": ["kubernetes/version.yaml", "README.md"],
      "matchStrings": [
        "version: (?<currentValue>v[\\d.]+)",
        "badge/Kubernetes-(?<currentValue>v[\\d.]+)-"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "kubernetes/kubernetes"
    },
    {
      "customType": "regex",
      "description": "Update Flux version in README badge and Dockerfile",
      "managerFilePatterns": [
        "README.md",
        ".devcontainer/Dockerfile"
      ],
      "matchStrings": [
        "badge/Flux-(?<currentValue>v[\\d.]+)-",
        "ARG FLUX_VERSION=(?<currentValue>v[\\d.]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "fluxcd/flux2"
    }
  ],
  "packageRules": [
    {
      "description": "Group Flux updates (gotk-components.yaml + README badge) into single PR",
      "matchDatasources": ["github-releases"],
      "matchPackageNames": ["fluxcd/flux2"],
      "groupName": "Flux"
    },
    {
      "description": "Group frequent kube-prometheus-stack updates into a single weekly PR and wait 3 days to ensure stability.",
      "matchManagers": ["flux"],
      "matchDepNames": ["kube-prometheus-stack"],
      "minimumReleaseAge": "3 days",
      "schedule": ["before 5am on Tuesday"]
    }
  ]
}
